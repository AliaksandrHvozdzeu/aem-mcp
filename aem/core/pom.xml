<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.hvozdzeu</groupId>
        <artifactId>hvozdzeu</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <!-- packaging=jar — standard Maven packaging.
         The OSGi MANIFEST.MF is generated by maven-bundle-plugin:manifest
         and embedded in the jar by maven-jar-plugin. This is more reliable than
         packaging=bundle, which requires the extension to load before POM scanning. -->
    <artifactId>hvozdzeu.core</artifactId>
    <packaging>jar</packaging>
    <name>hvozdzeu - Core Bundle</name>
    <description>OSGi bundle: Sling Models and Servlets</description>

    <dependencies>

        <!-- AEM uber-jar: all AEM/Sling/JCR APIs in one jar.
             classifier=apis is required and must match the entry in the parent
             dependencyManagement — otherwise Maven cannot resolve the version.
             scope=provided — jar is in the AEM runtime, not embedded in the bundle. -->
        <dependency>
            <groupId>com.adobe.aem</groupId>
            <artifactId>uber-jar</artifactId>
            <classifier>apis</classifier>
            <scope>provided</scope>
        </dependency>

        <!-- Sling Models API: @Model, @ValueMapValue, @Inject, @PostConstruct -->
        <dependency>
            <groupId>org.apache.sling</groupId>
            <artifactId>org.apache.sling.models.api</artifactId>
        </dependency>

        <!-- OSGi DS annotations: @Component, @Reference, @Activate, @Deactivate -->
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.component.annotations</artifactId>
        </dependency>

        <!-- OSGi Metatype: @Designate, @ObjectClassDefinition (configs in /system/console) -->
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>org.osgi.service.metatype.annotations</artifactId>
        </dependency>

        <!-- OSGi Core: Constants.SERVICE_RANKING, BundleContext, etc. -->
        <dependency>
            <groupId>org.osgi</groupId>
            <artifactId>osgi.core</artifactId>
        </dependency>

        <!-- Logging via SLF4J (AEM uses Logback under the hood) -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>

        <!-- JUnit 5 for unit tests -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
        </dependency>

    </dependencies>

    <build>
        <plugins>

            <!--
                maven-bundle-plugin: the manifest goal generates the OSGi MANIFEST.MF
                at target/classes/META-INF/MANIFEST.MF during the process-classes phase.
                maven-jar-plugin (below) then embeds that file in the final jar.

                This approach (packaging=jar + manifest goal) works reliably
                in a multi-module reactor without extension-loading issues.

                Key bnd instructions:
                  Bundle-SymbolicName  — unique bundle ID in Felix OSGi (required)
                  Export-Package       — packages visible to other bundles
                  Import-Package       — imports from the AEM environment (auto-derived from bytecode)
                  Sling-Model-Packages — packages that AEM scans for @Model registration
            -->
            <plugin>
                <groupId>org.apache.felix</groupId>
                <artifactId>maven-bundle-plugin</artifactId>
                <version>5.1.9</version>
                <executions>
                    <execution>
                        <id>bundle-manifest</id>
                        <!-- process-classes — after compilation, before packaging -->
                        <phase>process-classes</phase>
                        <goals>
                            <!-- manifest — generates MANIFEST.MF only, no packaging -->
                            <goal>manifest</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <instructions>
                        <Bundle-SymbolicName>com.hvozdzeu.core</Bundle-SymbolicName>
                        <Bundle-Name>hvozdzeu Core Bundle</Bundle-Name>
                        <Bundle-Description>Sling Models and Servlets for hvozdzeu project</Bundle-Description>
                        <Export-Package>
                            com.hvozdzeu.core.models;version="${project.version}",
                            com.hvozdzeu.core.servlets;version="${project.version}"
                        </Export-Package>
                        <Private-Package>
                            com.hvozdzeu.core.internal.*
                        </Private-Package>
                        <Sling-Model-Packages>
                            com.hvozdzeu.core.models
                        </Sling-Model-Packages>
                        <Import-Package>*</Import-Package>
                    </instructions>
                </configuration>
            </plugin>

            <!--
                maven-jar-plugin: packages compiled classes into a jar.
                manifestFile — tells it to use the MANIFEST.MF generated by
                maven-bundle-plugin instead of the default Maven manifest.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.3.0</version>
                <configuration>
                    <archive>
                        <manifestFile>
                            ${project.build.outputDirectory}/META-INF/MANIFEST.MF
                        </manifestFile>
                    </archive>
                </configuration>
            </plugin>

        </plugins>
    </build>

</project>
